# Copy to .env and tweak. Defaults match what PrintOps expects out of the box.

# Host ports. PrintOps's virtual-printer feature already binds 3000 and
# 3002, so the OrcaSlicer sidecar sits on 3003. Move them if you run
# this stack on a different host or want to free those ports for VPs.
ORCA_API_PORT=3003
BAMBU_API_PORT=3001

# Sidecar image tag. Default is `latest` (current stable release).
# Pinning options:
#   printops-X.Y.Z   pin to the sidecar image that shipped with PrintOps X.Y.Z
#                    (e.g. SIDECAR_TAG=printops-0.2.5)
#   daily            track the printops:daily channel
SIDECAR_TAG=latest
