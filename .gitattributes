# Force CRLF line endings for Windows batch files so cmd.exe can parse them
# regardless of the user's core.autocrlf setting.
*.bat text eol=crlf

# Vite preserves source line endings while injecting generated tags. Force the
# committed build entry point to LF so Windows builds do not become mixed-EOL.
static/index.html text eol=lf

# Runtime signature material is hash-verified byte-for-byte during Docker and
# installer builds. Keep its canonical LF representation on every platform.
backend/app/resources/pdf/verapdf-signing-key.asc text eol=lf

# Binary layout resources must never pass through line-ending conversion.
*.pdf binary
*.ttf binary
*.otf binary
